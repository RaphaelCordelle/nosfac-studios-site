# Variables d'environnement — docs/MASTER_SPECIFICATION.md section 21.1.
# Ne jamais committer de vraies valeurs ici : ce fichier documente les noms uniquement.

# URL canonique de l'environnement (Development/Preview/Production).
SITE_URL=http://localhost:3000

# Destination des demandes de contact. nosfac.studios@gmail.com au lancement.
CONTACT_TO_EMAIL=nosfac.studios@gmail.com

# Expéditeur vérifié par le fournisseur e-mail (requis pour activer l'envoi réel).
CONTACT_FROM_EMAIL=

# Clé API du fournisseur e-mail (Resend recommandé). Sans elle, le formulaire journalise
# les messages côté serveur au lieu de les envoyer (adapter de secours, voir src/services/email).
RESEND_API_KEY=

# Cloudflare Turnstile. Sans ces deux clés, la vérification anti-bot est ignorée (dev uniquement).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# DSN Sentry (optionnel, sans secret).
SENTRY_DSN=

# Active les analytics uniquement après décision et consentement (section 14.4).
ANALYTICS_ENABLED=false
