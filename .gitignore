# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
desktop.ini
Thumbs.db
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — .env.example is intentionally tracked (section 14.3: names only, never values)
.env*
!.env.example

# test artifacts
/test-results/
/playwright-report/
/blob-report/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
